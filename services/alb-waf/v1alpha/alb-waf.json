    "schemas": {
      "CRSConfigQuota": {
        "description": "CRS Config quota holds the limit and usage for Core Rule Set configuration resources",
        "properties": {
          "limit": {
            "description": "The maximum number of Core Rule Set configurations in this project.",
            "format": "int32",
            "maximum": 1000000,
            "minimum": -1,
            "title": "Max CRS configurations",
            "type": "integer"
          },
          "usage": {
            "description": "The number of Core Rule Set configurations that are currently existing in this project.",
            "format": "int32",
            "maximum": 1000000,
            "minimum": -1,
            "title": "Used CRS configurations",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "CRSRule": {
        "description": "Rule represents an individual security or validation rule.",
        "properties": {
          "description": {
            "description": "SQL Injection Attack Detected via libinjection",
            "example": "ENABLED",
            "type": "string"
          },
          "mode": {
            "description": "The current mode of the rule.",
            "enum": [
              "MODE_UNSPECIFIED",
              "MODE_ENABLED",
              "MODE_DISABLED",
              "MODE_LOG_ONLY"
            ],
            "example": "MODE_ENABLED",
            "pattern": "^(MODE_ENABLED|MODE_DISABLED|MODE_LOG_ONLY)$",
            "title": "OWASP Core Rule Set",
            "type": "string"
          },
          "severity": {
            "description": "Impact level.",
            "example": "CRITICAL",
            "pattern": "^(CRITICAL|ERROR|WARNING|INFO)$",
            "type": "string"
          }
        },
        "type": "object"
      },
      "CRSRuleGroup": {
        "description": "RuleGroup represents a collection of rules associated with a specific group.",
        "properties": {
          "description": {
            "description": "A description of what this group covers.",
            "example": "A description of what this group covers.",
            "type": "string"
          },
          "groupName": {
            "description": "The name for the rule group.",
            "example": "SQL Injection Attack (SQLI)",
            "pattern": "^[a-zA-Z\\(\\) ]+$",
            "type": "string"
          },
          "rules": {
            "additionalProperties": {
              "$ref": "#/components/schemas/CRSRule"
            },
            "type": "object"
          }
        },
        "type": "object"
      },
      "CustomRulesQuota": {
        "description": "Custom rules quotas holds the limit and usage for custom rules resources",
        "properties": {
          "limit": {
            "description": "The maximum number of custom rules in this project.",
            "format": "int32",
            "maximum": 1000000,
            "minimum": -1,
            "title": "Max custom rules",
            "type": "integer"
          },
          "usage": {
            "description": "The number of custom rules that currently existing in this project.",
            "format": "int32",
            "maximum": 1000000,
            "minimum": -1,
            "title": "Used custom rules",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "DeleteCoreRuleSetResponse": {
        "description": "DeleteCoreRuleSetResponse returns has empty body if successful.",
