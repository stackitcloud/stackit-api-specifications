  "info": {
    "description": "This API provides endpoints for managing Dremios.\n",
    "title": "STACKIT Dremio API",
    "version": "1alpha.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/v1alpha/projects/{projectId}/regions/{regionId}/dremios": {
      "get": {
        "description": "Returns a list of all dremio instances within the project.",
        "operationId": "list-dremios",
        "parameters": [
          {
            "$ref": "#/components/parameters/pageToken"
          },
          {
            "$ref": "#/components/parameters/pageSize"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/listDremiosResponse"
                }
              }
            },
            "description": "Successful response with all dremio instances."
          },
          "401": {
            "$ref": "#/components/responses/unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        },
        "x-stackit-authorization": {
          "actions": [
            "dremio.instance.list"
          ],
          "resource-id": "projectId",
          "resource-id-type": "dynamic",
          "resource-type": "project"
        }
      },
      "parameters": [
        {
          "$ref": "#/components/parameters/projectId"
        },
        {
          "$ref": "#/components/parameters/regionId"
        }
      ],
      "post": {
        "description": "Creates a new Dremio within the project.",
        "operationId": "create-dremio",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/create-dremioPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/dremioResponse"
                }
              }
            },
            "description": "Dremio has been accepted."
          },
          "400": {
            "$ref": "#/components/responses/badRequest"
          },
          "401": {
            "$ref": "#/components/responses/unauthorized"
          },
          "409": {
            "$ref": "#/components/responses/conflict"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        },
        "x-stackit-authorization": {
          "actions": [
            "dremio.instance.create"
          ],
          "resource-id": "projectId",
          "resource-id-type": "dynamic",
          "resource-type": "project"
        }
      }
    },
