  "openapi": "3.0.3",
  "paths": {
    "/v1/projects/{projectId}/regions/{regionId}/instances": {
      "get": {
        "description": "list instances in a project",
        "operationId": "ListInstances",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListInstancesResponse"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "$ref": "#/components/responses/BadRequestResponse"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedResponse"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenResponse"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundResponse"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequestsResponse"
          }
        },
        "summary": "list instances in a project",
        "x-stackit-authorization": {
          "actions": [
            "model-experiments.instance.list"
          ],
          "resource-id": "projectId",
          "resource-id-type": "dynamic",
          "resource-type": "project",
          "service-enablement": {
            "services": [
              "cloud.stackit.model-experiments"
            ]
          }
        }
      },
      "parameters": [
        {
          "description": "portal project id",
          "example": "792ff0e7-be72-4135-91fa-74adab5cec76",
          "in": "path",
          "name": "projectId",
          "required": true,
          "schema": {
            "format": "uuid",
            "type": "string"
          },
          "style": "simple"
        },
        {
          "description": "region id",
          "example": "eu01",
          "in": "path",
          "name": "regionId",
          "required": true,
          "schema": {
            "enum": [
              "eu01"
            ],
            "type": "string"
          },
          "style": "simple"
        }
      ],
      "post": {
        "description": "create an instance in a project",
        "operationId": "CreateInstance",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInstancePayload"
              }
            }
          }
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateInstanceResponse"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "$ref": "#/components/responses/BadRequestResponse"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedResponse"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenResponse"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundResponse"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequestsResponse"
          }
        },
        "summary": "create an instance in a project",
        "x-stackit-authorization": {
          "actions": [
            "model-experiments.instance.create"
          ],
          "resource-id": "projectId",
          "resource-id-type": "dynamic",
          "resource-type": "project",
          "service-enablement": {
            "services": [
              "cloud.stackit.model-experiments"
            ]
          }
        }
      }
    },
