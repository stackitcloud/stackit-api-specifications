        "style": "simple"
      },
      "regionId": {
        "description": "region name",
        "example": "eu01",
        "in": "path",
        "name": "regionId",
        "required": true,
        "schema": {
          "enum": [
            "eu01"
          ],
          "type": "string"
        },
        "style": "simple"
      },
      "tokenId": {
        "description": "token id",
        "example": "94649fc3-5e97-4229-a891-b840f6bd67a8",
        "in": "path",
        "name": "tokenId",
        "required": true,
        "schema": {
          "format": "uuid",
          "type": "string"
        },
        "style": "simple"
