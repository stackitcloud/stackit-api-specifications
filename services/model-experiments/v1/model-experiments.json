    "schemas": {
      "CreateInstancePayload": {
        "properties": {
          "deletedExperimentRetention": {
            "$ref": "#/components/schemas/DeletedExperimentRetention"
          },
          "description": {
            "example": "My AI Model Experiments instance for project X",
            "maxLength": 160,
            "pattern": "^[0-9a-zA-Z\\s.:\\/\\-]*$",
            "type": "string"
          },
          "labels": {
            "$ref": "#/components/schemas/Labels"
          },
          "name": {
            "example": "my-ai-model-experiments-instance",
            "maxLength": 64,
            "pattern": "^[0-9a-zA-Z\\s_-]+$",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "CreateInstanceResponse": {
        "properties": {
          "instance": {
            "$ref": "#/components/schemas/Instance"
          },
          "message": {
            "example": "successfully created instance",
            "type": "string"
          }
        },
        "required": [
          "instance"
        ],
        "type": "object"
      },
      "CreateInstanceTokenPayload": {
        "properties": {
          "description": {
            "example": "Token for my service account",
            "maxLength": 160,
            "pattern": "^[0-9a-zA-Z\\s.:\\/\\-]*$",
            "type": "string"
          },
          "labels": {
            "$ref": "#/components/schemas/Labels"
          },
          "name": {
            "example": "my-service-account-token",
            "maxLength": 64,
            "minLength": 1,
            "pattern": "^[0-9a-zA-Z\\s_-]+$",
            "type": "string"
          },
          "ttlDuration": {
            "description": "time to live duration. Must be valid duration string. Maximum\nallowed duration is 6 months. If not set, defaults to 6 months.\n",
            "example": "5h30m40s",
            "format": "duration",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "CreateInstanceTokenResponse": {
        "properties": {
          "message": {
            "example": "successfully created instance token",
            "type": "string"
          },
          "token": {
            "$ref": "#/components/schemas/Token"
          }
        },
        "required": [
          "token"
        ],
        "type": "object"
      },
      "DeleteInstanceResponse": {
        "properties": {
          "instance": {
            "$ref": "#/components/schemas/Instance"
          },
          "message": {
            "example": "successfully deleted instance",
            "type": "string"
          }
        },
        "required": [
          "instance"
        ],
        "type": "object"
      },
      "DeleteInstanceTokenResponse": {
        "properties": {
          "message": {
            "example": "successfully deleted instance token",
            "type": "string"
          },
          "token": {
            "$ref": "#/components/schemas/TokenMetadata"
          }
        },
        "required": [
          "token"
        ],
        "type": "object"
      },
      "DeletedExperimentRetention": {
        "description": "The duration to retain experiments marked for deletion before they are permanently purged. Min: 1d, Max: 90d.",
        "example": "30d",
        "pattern": "^([0-9]+(\\.[0-9]+)?d)?([0-9]+(\\.[0-9]+)?h)?([0-9]+(\\.[0-9]+)?m)?([0-9]+(\\.[0-9]+)?s)?$",
        "type": "string"
      },
      "ErrorResponse": {
        "properties": {
          "code": {
            "description": "The HTTP status code.",
            "format": "int32",
            "type": "integer"
          },
          "message": {
            "description": "User facing error message.",
            "type": "string"
          },
          "status": {
            "description": "The canonical error code.",
            "type": "string"
          }
        },
        "required": [
          "message",
          "code"
        ],
        "type": "object"
      },
      "GetInstanceResponse": {
        "properties": {
          "instance": {
            "$ref": "#/components/schemas/Instance"
          },
          "message": {
            "example": "successfully fetched instance",
            "type": "string"
          }
        },
        "required": [
          "instance"
        ],
        "type": "object"
      },
      "GetInstanceTokenResponse": {
        "properties": {
          "message": {
            "example": "successfully fetched instance token",
            "type": "string"
          },
          "token": {
            "$ref": "#/components/schemas/TokenMetadata"
          }
        },
        "required": [
          "token"
        ],
        "type": "object"
      },
      "Instance": {
        "properties": {
          "bucketName": {
            "pattern": "^model-experiments-[a-zA-Z0-9]+$",
            "type": "string"
          },
          "deletedExperimentRetention": {
            "$ref": "#/components/schemas/DeletedExperimentRetention"
          },
          "description": {
            "example": "My AI Model Experiments instance for project X",
            "maxLength": 160,
            "pattern": "^[0-9a-zA-Z\\s.:\\/\\-]+$",
            "type": "string"
          },
          "errorMessage": {
            "type": "string"
          },
          "id": {
            "example": "57d11a2b-7366-46a7-9f45-2e0ebd079142",
            "format": "uuid",
            "type": "string"
          },
          "labels": {
            "$ref": "#/components/schemas/Labels"
          },
          "name": {
            "example": "my-ai-model-experiments-instance",
            "maxLength": 64,
            "minLength": 1,
            "pattern": "^[0-9a-zA-Z\\s_-]+$",
            "type": "string"
          },
          "region": {
            "example": "eu01",
            "type": "string"
          },
          "state": {
            "enum": [
              "pending",
              "creating",
              "updating",
              "active",
              "deleting",
              "impaired",
              "reconciling"
            ],
            "example": "creating",
            "type": "string"
          },
          "url": {
            "example": "https://57d11a2b-7366-46a7-9f45-2e0ebd079142.model-experiments.eu01.stackit.cloud",
            "maxLength": 1000,
            "pattern": "^[0-9a-zA-Z\\s.:\\/\\-]+$",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "state",
          "url"
        ],
        "type": "object"
      },
      "LabelPatch": {
        "additionalProperties": {
          "maxLength": 63,
          "nullable": true,
          "pattern": "^(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])*$",
          "type": "string"
        },
        "description": "Object that represents the labels of an object. Regex for keys: `^([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9]$`. Regex for values: `^(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])*$`. Providing a `null` value for a key will remove that key. The `stackit-` prefix is reserved and cannot be used for Keys.",
        "example": {
          "key": "value"
        },
        "type": "object"
      },
      "Labels": {
        "additionalProperties": {
          "maxLength": 63,
          "pattern": "^(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])*$",
          "type": "string"
        },
        "description": "Object that represents the labels of an object. Regex for keys: `^([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9]$`. Regex for values: `^(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])*$`. Providing a `null` value for a key will remove that key. The `stackit-` prefix is reserved and cannot be used for Keys.",
        "example": {
          "key": "value"
        },
        "type": "object"
      },
      "ListInstanceTokensResponse": {
        "properties": {
          "message": {
            "example": "successfully fetched instance tokens",
            "type": "string"
          },
          "tokens": {
            "items": {
              "$ref": "#/components/schemas/TokenMetadata"
            },
            "type": "array"
          }
        },
        "required": [
          "tokens"
        ],
        "type": "object"
      },
      "ListInstancesResponse": {
        "properties": {
          "instances": {
            "items": {
              "$ref": "#/components/schemas/Instance"
            },
            "type": "array"
          },
          "message": {
            "example": "successfully fetched instances",
            "type": "string"
          }
        },
        "required": [
          "instances"
        ],
        "type": "object"
      },
      "PartialUpdateInstancePayload": {
        "properties": {
          "deletedExperimentRetention": {
            "$ref": "#/components/schemas/DeletedExperimentRetention"
          },
          "description": {
            "example": "My updated AI Model Experiments instance for project X",
            "maxLength": 160,
            "pattern": "^[0-9a-zA-Z\\s.:\\/\\-]*$",
            "type": "string",
            "x-go-type-skip-optional-pointer": false
          },
          "labels": {
            "$ref": "#/components/schemas/LabelPatch"
          },
          "name": {
            "example": "my-updated-ai-model-experiments-instance",
            "maxLength": 64,
            "pattern": "^[0-9a-zA-Z\\s_-]*$",
            "type": "string",
            "x-go-type-skip-optional-pointer": false
          }
        },
        "type": "object"
      },
      "PartialUpdateInstanceResponse": {
        "properties": {
          "instance": {
            "$ref": "#/components/schemas/Instance"
          },
          "message": {
            "example": "successfully updated instance",
            "type": "string"
          }
        },
        "required": [
          "instance"
        ],
        "type": "object"
      },
      "PartialUpdateInstanceTokenPayload": {
        "properties": {
          "description": {
            "example": "My updated token for my service account",
            "maxLength": 2000,
            "pattern": "^[0-9a-zA-Z\\s.:\\/\\-]*$",
            "type": "string",
            "x-go-type-skip-optional-pointer": false
          },
          "labels": {
            "$ref": "#/components/schemas/LabelPatch"
          },
          "name": {
            "example": "my-updated-service-account-token",
            "maxLength": 200,
            "minLength": 1,
            "pattern": "^[0-9a-zA-Z\\s_-]*$",
            "type": "string",
            "x-go-type-skip-optional-pointer": false
          }
        },
        "type": "object"
      },
      "PartialUpdateInstanceTokenResponse": {
        "properties": {
          "message": {
            "example": "successfully updated instance token",
            "type": "string"
          },
          "token": {
            "$ref": "#/components/schemas/TokenMetadata"
          }
        },
        "required": [
          "token"
        ],
        "type": "object"
      },
      "Token": {
        "properties": {
          "content": {
            "example": "eyJhbGciOiJIUzI1NiJ9.e30.ZRrHA1JJJW8opsbCGfG_HACGpVJo0r8DWeHelLTC9ar",
            "format": "jwt",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+$",
            "type": "string"
          },
          "description": {
            "example": "Token for my service account",
            "maxLength": 160,
            "pattern": "^[0-9a-zA-Z\\s.:\\/\\-]+$",
            "type": "string"
          },
          "id": {
            "example": "94649fc3-5e97-4229-a891-b840f6bd67a8",
            "format": "uuid",
            "type": "string"
          },
          "labels": {
            "$ref": "#/components/schemas/Labels"
          },
          "name": {
            "example": "my-service-account-token",
            "maxLength": 64,
            "minLength": 1,
            "pattern": "^[0-9a-zA-Z\\s_-]+$",
            "type": "string"
          },
          "region": {
            "example": "eu01",
            "type": "string"
          },
          "state": {
            "$ref": "#/components/schemas/TokenState"
          },
          "validUntil": {
            "example": "2025-08-26T10:40:52Z",
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "content",
          "state",
          "validUntil",
          "name",
          "region"
        ],
        "type": "object"
      },
      "TokenMetadata": {
        "properties": {
          "description": {
            "example": "Token for my service account",
            "maxLength": 160,
            "pattern": "^[0-9a-zA-Z\\s.:\\/\\-]+$",
            "type": "string"
          },
          "id": {
            "example": "94649fc3-5e97-4229-a891-b840f6bd67a8",
            "format": "uuid",
            "type": "string"
          },
          "labels": {
            "$ref": "#/components/schemas/Labels"
          },
          "name": {
            "example": "my-service-account-token",
            "maxLength": 64,
            "minLength": 1,
            "pattern": "^[0-9a-zA-Z\\s_-]+$",
            "type": "string"
          },
          "region": {
            "example": "eu01",
            "type": "string"
          },
          "state": {
            "$ref": "#/components/schemas/TokenState"
          },
          "validUntil": {
            "example": "2025-08-26T10:40:52Z",
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "state",
          "validUntil",
          "name",
          "region"
        ],
        "type": "object"
      },
      "TokenState": {
        "description": "The lifecycle state of the token.",
        "enum": [
          "creating",
          "active",
          "deleting",
          "inactive"
        ],
        "example": "creating",
        "type": "string"
      }
    }
  },
  "info": {
    "contact": {
      "email": "stackit-model-experiments@stackit.cloud",
      "name": "STACKIT AI Model Experiments",
