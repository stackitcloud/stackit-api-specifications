            "minLength": 1,
            "pattern": "^[a-zA-Z0-9 -]*$",
            "type": "string"
          },
          "id": {
            "description": "An auto generated unique id which identifies the resource.",
            "format": "uuid",
            "maxLength": 36,
            "minLength": 36,
            "type": "string"
          },
          "settings": {
            "$ref": "#/components/schemas/topicSettings"
          },
          "state": {
            "description": "The current state of the resource.",
            "enum": [
              "reconciling",
              "active",
              "deleting"
            ],
            "type": "string"
          },
          "uri": {
            "description": "The URI for reaching the resource.",
            "maxLength": 1024,
            "type": "string"
          }
        },
        "required": [
          "id",
          "displayName",
          "state",
          "createTime"
        ]
      },
      "topicSettings": {
        "description": "Configuration settings for the topic.",
        "properties": {
          "acl": {
            "default": [
              "0.0.0.0/0"
            ],
            "description": "Whitelist of IPs in CIDR notation that can access the topic and its underlying subscriptions.",
            "example": [
              "192.168.1.0/24",
              "192.168.2.0/24"
            ],
            "items": {
              "example": "192.168.1.0/24",
              "format": "cidr",
              "type": "string"
            },
            "maxItems": 100,
            "type": "array"
          },
          "retention": {
            "default": "168h",
            "description": "The maximum length of time a message is persisted in storage. \nMessages older than this duration are automatically discarded/deleted.\n\n**Format:**\nMust be a scalar duration: a number (integer or decimal) followed by a unit ('s', 'm', or 'h').\n\n**Constraints:**\n- **Minimum:** \"1s\"\n- **Maximum:** \"168h\" (7 days)\n",
