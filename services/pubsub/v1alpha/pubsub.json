          "id",
          "displayName",
          "topicId",
          "state",
          "createTime"
        ]
      },
      "subscriptionSettings": {
        "description": "Configuration settings for the subscription.",
        "properties": {
          "ackDeadline": {
            "default": "2m",
            "description": "The maximum amount of time the system waits for a message acknowledgment. \nIf a message is not acknowledged within this window, it will be redelivered.\n\n**Format:**\nMust be a duration string consisting of a number (integer or decimal) followed by a unit ('s', 'm', or 'h').\n\n**Constraints:**\n- **Minimum:** \"1s\"\n- **Maximum:** \"168h\" (7 days)\n",
            "example": "60s",
            "pattern": "^[0-9]+(\\.[0-9]+)?(s|m|h)$",
            "type": "string"
          }
        },
        "type": "object"
      },
      "topicResponse": {
        "properties": {
          "createTime": {
            "description": "The point in time the resource was created.",
            "format": "date-time",
            "maxLength": 128,
            "type": "string"
          },
          "description": {
            "description": "The description is a longer text chosen by the user to provide more context for the resource.",
            "maxLength": 1024,
            "type": "string"
          },
