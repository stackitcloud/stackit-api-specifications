    "schemas": {
      "ApproveSubscriptionPayload": {
        "properties": {
          "instanceTarget": {
            "description": "The target URL of the user instance, used to redirect the user to the instance after the subscription is active.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "ErrorResponse": {
        "properties": {
          "error": {
            "description": "Reason phrase of the status code.",
            "example": "Not Found",
            "type": "string"
          },
          "message": {
            "description": "Description of the error.",
            "example": "Error message example.",
            "type": "string"
          },
          "path": {
            "description": "Path which was called.",
            "example": "/path/where/error/occurred",
            "type": "string"
          },
          "status": {
            "description": "HTTP response status code.",
            "example": 404,
            "format": "int32",
            "type": "integer"
          },
          "timeStamp": {
            "description": "Timestamp at which the error occurred.",
            "example": "2019-08-24T14:15:22Z",
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "error",
          "message",
          "path",
          "status",
          "timeStamp"
        ]
      },
      "ResolveCustomerPayload": {
        "properties": {
          "token": {
            "description": "Opaque token exchangeable for subscription details.",
            "type": "string"
          }
        },
        "required": [
          "token"
        ],
        "type": "object"
      },
      "consumers-subscriptions-createPayload": {
        "properties": {
          "consumerNotificationEmail": {
            "description": "An E-Mail address the vendor can reach the consuer about subscription updates.",
            "type": "string"
          },
          "productId": {
            "description": "The user-readable ID of the product.",
            "type": "string"
          },
          "sku": {
            "description": "The concrete variant of the product.",
            "type": "string"
          }
        },
        "required": [
          "productId",
          "sku"
        ],
        "type": "object"
      },
      "marketplace.subscription.v1.Assets": {
        "properties": {
          "endUserLicenseAgreement": {
            "$ref": "#/components/schemas/marketplace.subscription.v1.File"
          },
          "productDescription": {
            "$ref": "#/components/schemas/marketplace.subscription.v1.File"
          },
          "serviceCertificate": {
            "$ref": "#/components/schemas/marketplace.subscription.v1.File"
          },
          "serviceLevelAgreement": {
            "$ref": "#/components/schemas/marketplace.subscription.v1.File"
          }
        },
        "type": "object"
      },
      "marketplace.subscription.v1.File": {
        "properties": {
          "version": {
            "$ref": "#/components/schemas/marketplace.subscription.v1.File_LocalizedVersion"
          }
        },
        "type": "object"
      },
      "marketplace.subscription.v1.File_LocalizedVersion": {
        "properties": {
          "de": {
            "description": "The file version matching the file name (localized).",
            "type": "string"
          },
          "en": {
            "description": "The file version matching the file name (localized).",
            "type": "string"
          }
        },
        "type": "object"
      },
      "marketplace.subscription.v1.ListSubscriptionsResponse": {
        "properties": {
          "cursor": {
            "type": "string"
          },
          "items": {
            "items": {
              "$ref": "#/components/schemas/marketplace.subscription.v1.Subscription"
            },
            "type": "array"
          },
          "limit": {
            "type": "integer"
          }
        },
        "type": "object"
      },
      "marketplace.subscription.v1.Subscription": {
        "properties": {
          "approvalTimeout": {
            "description": "Period between the subscription was created until the approval needs to happen.",
            "readOnly": true,
            "type": "string"
          },
          "autoRenewal": {
            "description": "If true, the the subscription will extend its validity automatically at the end of the current period.",
            "readOnly": true,
            "type": "boolean"
          },
          "lifecycleState": {
            "enum": [
              "STATE_UNSPECIFIED",
              "SUBSCRIPTION_PENDING",
              "SUBSCRIPTION_ACTIVE",
              "SUBSCRIPTION_INACTIVE",
              "SUBSCRIPTION_CANCELLING",
              "SUBSCRIPTION_CANCELLED",
              "SUBSCRIPTION_REJECTED",
              "SUBSCRIPTION_APPROVAL_TIMED_OUT"
            ],
            "readOnly": true,
            "type": "string"
          },
          "orderedAt": {
            "description": "When the subscription was ordered.",
            "readOnly": true,
            "type": "string"
          },
          "organizationId": {
            "description": "The UUID of the organization.",
            "readOnly": true,
            "type": "string"
          },
          "product": {
            "allOf": [
              {
                "$ref": "#/components/schemas/marketplace.subscription.v1.SubscriptionProduct"
              }
            ],
            "description": "The product to the subscription.",
            "readOnly": true
          },
          "projectId": {
            "description": "The UUID of the project.",
            "readOnly": true,
            "type": "string"
          },
          "subscriptionId": {
            "description": "The UUID of the subscription.",
            "readOnly": true,
            "type": "string"
          },
          "terminatesAt": {
            "description": "Timestamp when the subscription will finally terminate.",
            "readOnly": true,
            "type": "string"
          },
          "validFrom": {
            "description": "Timestamp when the subscription validity has started.",
            "readOnly": true,
            "type": "string"
          },
          "validUntil": {
            "description": "Timestamp when the current subscription validity will end. May be automatically renewed.",
            "readOnly": true,
            "type": "string"
          }
        },
        "required": [
          "organizationId",
          "projectId",
          "subscriptionId",
          "product",
          "lifecycleState",
          "orderedAt"
        ],
        "type": "object"
      },
      "marketplace.subscription.v1.SubscriptionProduct": {
        "properties": {
          "assets": {
            "$ref": "#/components/schemas/marketplace.subscription.v1.Assets"
          },
          "deliveryMethod": {
            "description": "The product delivery method/type. For reference: SAAS - Software as a Service, SAI - STACKIT Application Image",
            "enum": [
              "SAAS",
              "KUBERNETES",
              "SAI",
              "PROFESSIONAL_SERVICE"
            ],
            "readOnly": true,
            "type": "string"
          },
          "lifecycleState": {
            "description": "The lifecycle state of the product.",
            "enum": [
              "PRODUCT_LIVE",
              "PRODUCT_PENDING_APPROVAL",
              "PRODUCT_PREVIEW"
            ],
            "readOnly": true,
            "type": "string"
          },
          "planId": {
            "description": "The user-readable plan ID of a pricing option.",
            "type": "string"
          },
          "priceType": {
            "description": "The product's price type.",
            "enum": [
              "CONTRACT",
              "FREE",
              "FREE_TRIAL",
              "BYOL",
              "PAYG"
            ],
            "readOnly": true,
            "type": "string"
          },
          "pricingPlan": {
            "description": "Additional price type information.",
            "type": "string"
          },
          "productId": {
            "description": "The user-readable ID of the product.",
            "type": "string"
          },
          "productName": {
            "description": "The name of the product.",
            "type": "string"
          },
          "vendorName": {
            "description": "The product vendor's name.",
            "type": "string"
          },
          "vendorPlanId": {
            "description": "The vendor provided plan ID.",
            "type": "string"
          },
          "vendorProductId": {
            "description": "The vendor provided prduct ID.",
            "type": "string"
          },
          "vendorWebsiteUrl": {
            "description": "The vendor's website.",
            "type": "string"
          }
        },
        "required": [
          "deliveryMethod",
          "lifecycleState",
          "planId",
          "priceType",
          "pricingPlan",
          "productId",
          "productName",
          "vendorName",
          "vendorWebsiteUrl"
        ],
        "type": "object"
      },
      "marketplace.subscription.v1.SubscriptionRedirect": {
        "properties": {
          "redirectTarget": {
            "type": "string"
          },
          "redirectUrl": {
            "type": "string"
          }
        },
        "required": [
          "redirectTarget",
          "redirectUrl"
        ],
        "type": "object"
      }
    }
  },
