  "info": {
    "description": "This API provides endpoints for managing Telemetry Routers.\n",
    "title": "STACKIT Telemetry Router API",
    "version": "1beta.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/v1beta/projects/{projectId}/regions/{regionId}/telemetry-routers": {
      "get": {
        "description": "Returns a list of all Telemetry Routers within the project.",
        "operationId": "list-telemetry-routers",
        "parameters": [
          {
            "$ref": "#/components/parameters/pageToken"
          },
          {
            "$ref": "#/components/parameters/pageSize"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/listTelemetryRoutersResponse"
                }
              }
            },
            "description": "Successful response with all Telemetry Routers."
          },
          "400": {
            "$ref": "#/components/responses/badRequest"
          },
          "401": {
            "$ref": "#/components/responses/unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        },
        "x-stackit-authorization": {
          "actions": [
            "telemetry-router.instance.list"
          ],
          "resource-id": "projectId",
          "resource-id-type": "dynamic",
          "resource-type": "project"
        }
      },
      "parameters": [
        {
          "$ref": "#/components/parameters/projectId"
        },
        {
          "$ref": "#/components/parameters/regionId"
        }
      ],
      "post": {
        "description": "Creates the new Telemetry Router within the project.",
        "operationId": "create-telemetry-router",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/create-telemetry-routerPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/telemetryRouterResponse"
                }
              }
            },
            "description": "Telemetry Router was created successfully"
          },
          "400": {
            "$ref": "#/components/responses/badRequest"
          },
          "401": {
            "$ref": "#/components/responses/unauthorized"
          },
          "409": {
            "$ref": "#/components/responses/conflict"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        },
        "x-stackit-authorization": {
          "actions": [
            "telemetry-router.instance.create"
          ],
          "resource-id": "projectId",
          "resource-id-type": "dynamic",
          "resource-type": "project"
        }
      }
    },
    "/v1beta/projects/{projectId}/regions/{regionId}/telemetry-routers/{telemetryRouterId}": {
      "delete": {
        "description": "Deletes the given Telemetry Router.",
        "operationId": "delete-telemetry-router",
        "parameters": [
          {
            "$ref": "#/components/parameters/force"
          }
        ],
        "responses": {
          "204": {
            "description": "Telemetry Router was deleted successfully."
          },
          "400": {
            "$ref": "#/components/responses/badRequest"
          },
          "401": {
            "$ref": "#/components/responses/unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/notFound"
          },
          "409": {
            "$ref": "#/components/responses/conflict"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        },
        "x-stackit-authorization": {
          "actions": [
            "telemetry-router.instance.delete"
          ],
          "resource-id": "projectId",
          "resource-id-type": "dynamic",
          "resource-type": "project"
        }
      },
      "get": {
        "description": "Returns the details for the given Telemetry Router.",
        "operationId": "get-telemetry-router",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/telemetryRouterResponse"
                }
              }
            },
            "description": "Telemetry Router returned successfully."
          },
          "400": {
            "$ref": "#/components/responses/badRequest"
          },
          "401": {
            "$ref": "#/components/responses/unauthorized"
          },
          "409": {
            "$ref": "#/components/responses/conflict"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        },
        "x-stackit-authorization": {
          "actions": [
            "telemetry-router.instance.get"
          ],
          "resource-id": "projectId",
          "resource-id-type": "dynamic",
          "resource-type": "project"
        }
      },
      "parameters": [
        {
          "$ref": "#/components/parameters/projectId"
        },
        {
          "$ref": "#/components/parameters/regionId"
        },
        {
          "$ref": "#/components/parameters/telemetryRouterId"
        }
      ],
      "put": {
        "description": "Updates the given Telemetry Router.",
        "operationId": "update-telemetry-router",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/update-telemetry-routerPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/telemetryRouterResponse"
                }
              }
            },
            "description": "Telemetry Router was updated successfully."
          },
          "400": {
            "$ref": "#/components/responses/badRequest"
          },
          "401": {
            "$ref": "#/components/responses/unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/notFound"
          },
          "409": {
            "$ref": "#/components/responses/conflict"
          },
          "500": {
            "$ref": "#/components/responses/internalServerError"
          }
        },
        "x-stackit-authorization": {
          "actions": [
            "telemetry-router.instance.update"
          ],
          "resource-id": "projectId",
          "resource-id-type": "dynamic",
          "resource-type": "project"
        }
      }
    },
    "/v1beta/projects/{projectId}/regions/{regionId}/telemetry-routers/{telemetryRouterId}/access-tokens": {
      "get": {
        "description": "Get all access tokens for a telemetry router.",
        "operationId": "list-access-tokens",
        "parameters": [
          {
            "$ref": "#/components/parameters/pageToken"
          },
          {
            "$ref": "#/components/parameters/pageSize"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
