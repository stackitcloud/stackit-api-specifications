        "name": "region",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "regionId": {
        "description": "The STACKIT region name the resource is located in.",
        "in": "path",
        "name": "regionId",
        "required": true,
        "schema": {
          "enum": [
            "eu01",
            "eu02"
          ],
          "type": "string"
        }
      },
      "ruleFilters": {
        "description": "Filtering criteria for the export",
        "explode": true,
        "in": "query",
        "name": "filters",
        "schema": {
          "properties": {
            "direction": {
              "type": "string"
            },
            "etherType": {
              "type": "string"
            },
            "instanceName": {
              "type": "string"
            },
            "portRange": {
              "type": "string"
            },
            "product": {
              "type": "string"
            },
            "protocol": {
              "type": "string"
            },
            "sourceIP": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "style": "form"
      },
      "securityGroupId": {
        "description": "The UUID of the group.",
        "in": "query",
        "name": "securityGroupId",
        "schema": {
          "type": "string"
        }
      },
      "serviceId": {
        "description": "The STACKIT service the resource belongs to.",
        "in": "path",
        "name": "serviceId",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "sortBy": {
        "description": "The field to sort the response by.",
        "in": "query",
        "name": "sortBy",
        "schema": {
          "type": "string"
        }
      },
      "sortOrder": {
        "description": "The order to sort the response by.",
        "in": "query",
        "name": "sortOrder",
        "schema": {
          "enum": [
            "asc",
            "desc"
          ],
          "type": "string"
        }
      },
      "sourceIP": {
        "description": "The IP for the rule.",
        "example": "1.2.3.4/32",
        "in": "query",
        "name": "sourceIP",
        "schema": {
          "type": "string"
        }
      },
      "type": {
        "description": "The type of the rule (e.g., \"ACL\", \"PublicIP\", \"SecurityRule\").",
        "in": "query",
        "name": "type",
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "badRequest": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        },
        "description": "Bad Request. The data provided by the client did not match expectations."
      },
      "internalServerError": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
