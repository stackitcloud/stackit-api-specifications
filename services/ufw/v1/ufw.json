          },
          "direction": {
            "description": "The direction of the traffic, typically \"ingress\" or \"egress\".",
            "example": "ingress",
            "type": "string"
          },
          "etherType": {
            "description": "Specifies the bound of the rule.",
            "example": "IPv4",
            "type": "string"
          },
          "instanceId": {
            "description": "The ID of the product, similar to a project ID.",
            "example": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
            "type": "string"
          },
          "offset": {
            "description": "Position in the list.",
            "example": "1",
            "format": "int32",
            "type": "integer"
          },
          "portRange": {
            "description": "The Port range to which the rule applies.",
            "example": "8080-8090",
            "type": "string"
          },
          "product": {
            "description": "The source service (e.g., Load Balancer, Redis).",
            "example": "Load Balancer",
            "type": "string"
          },
          "protocol": {
            "description": "The network protocol (e.g., \"TCP\", \"UDP\", \"ICMP\").",
            "example": "TCP",
            "type": "string"
          },
          "securityGroupId": {
            "description": "The ID of the Group.",
            "example": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
            "type": "string"
          },
          "sourceIP": {
            "description": "The IP (CIDR) to which the rule applies.",
            "example": "0.0.0.0/0",
            "type": "string"
          },
          "type": {
            "description": "The type of the rule (e.g., \"ACL\", \"PublicIP\", \"SecurityRule\").",
            "example": "ACL",
            "type": "string"
          }
