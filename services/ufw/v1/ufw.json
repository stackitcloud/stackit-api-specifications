{
  "components": {
    "parameters": {
      "cursor": {
        "description": "A pagination cursor that represents a position in the dataset. If given, results will be returned from the item after the cursor. If not given, results will be returned from the beginning.",
        "in": "query",
        "name": "cursor",
        "schema": {
          "type": "string"
        }
      },
      "direction": {
        "description": "The direction of the rule (e.g., \"ingress\", \"egress\").",
        "in": "query",
        "name": "direction",
        "schema": {
          "enum": [
            "ingress",
            "egress"
          ],
          "type": "string"
        }
      },
      "etherType": {
        "description": "The ether type for the rule.",
        "in": "query",
        "name": "etherType",
        "schema": {
          "type": "string"
        }
      },
      "folderId": {
        "description": "The STACKIT portal folder UUID the key ring is part of.",
        "in": "path",
        "name": "folderId",
        "required": true,
        "schema": {
          "format": "uuid",
          "type": "string"
        }
      },
      "instanceIdPath": {
        "description": "The ID of the source, similar to a project ID but for the product service instance.",
        "in": "path",
        "name": "instanceId",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "instanceIdQuery": {
        "description": "The ID of the source, similar to a project ID but for the product service instance.",
        "in": "query",
        "name": "instanceId",
        "schema": {
          "type": "string"
        }
      },
      "limit": {
        "description": "The maximum number of items to return in the response. If maximum is exceeded, maximum is used.",
        "in": "query",
        "name": "limit",
        "schema": {
          "format": "int32",
          "type": "integer"
        }
      },
      "offset": {
        "description": "The offset for the rule in the instance it is associated with.",
        "in": "query",
        "name": "offset",
        "schema": {
          "format": "int32",
          "type": "integer"
